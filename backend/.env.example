# ---- Server ----
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# ---- Database (Supabase / any Postgres) ----
DATABASE_URL="postgresql://user:password@localhost:5432/ruth?schema=public"

# ---- Auth ----
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ---- Email (Nodemailer / SMTP — e.g. Resend, SendGrid SMTP, or Gmail app password) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM="Ruth <noreply@ruthjournal.app>"

# ---- Image storage (Cloudinary) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- AI (OpenAI) ----
OPENAI_API_KEY=sk-replace_me
OPENAI_MODEL=gpt-4o-mini

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
